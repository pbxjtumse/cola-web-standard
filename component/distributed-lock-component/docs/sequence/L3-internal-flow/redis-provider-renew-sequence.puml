@startuml
!include ../../_common/style.puml
title RedisLockProvider.renew() 内部时序图

participant Watchdog as "Watchdog / Handle"
participant Provider as "RedisLockProvider"
participant Executor as "RedisLockScriptExecutor"
database Redis

Watchdog -> Provider : renew(request)
Provider -> Executor : execute renew.lua\nKEYS[lockKey]\nARGV[ownerToken, leaseMillis]
Executor -> Redis : EVAL renew.lua
alt owner matched
    Redis --> Executor : 1
    Executor --> Provider : RENEWED
    Provider --> Watchdog : LockRenewResponse(RENEWED)
else key not found
    Redis --> Executor : -1
    Executor --> Provider : NOT_FOUND
    Provider --> Watchdog : LockRenewResponse(NOT_FOUND)
else owner not matched
    Redis --> Executor : 0
    Executor --> Provider : NOT_OWNER
    Provider --> Watchdog : LockRenewResponse(NOT_OWNER)
else redis error
    Redis --> Executor : error
    Executor --> Provider : PROVIDER_ERROR
    Provider --> Watchdog : LockRenewResponse(PROVIDER_ERROR)
end

@enduml
